<!-- ========================================================================
     MainWindow.xaml
     メインウィンドウの画面定義
     ========================================================================
     アプリケーションのメイン画面。登録済みメールアカウントの未読状況を
     一覧表示する。起動時は非表示(トレイ常駐)で、トレイアイコンの
     ダブルクリックや「表示」メニューで表示される。

     画面構成:
       - ヘッダー部: アプリ名、ステータス表示、操作ボタン
       - 一覧部: 各アカウントの未読数・最終チェック時刻・エラー表示

     ウィンドウの動作:
       - ×ボタン(Closing): ウィンドウを非表示にする(トレイに常駐)
       - 最小化(StateChanged): ウィンドウを非表示にする
     ======================================================================== -->
<Window x:Class="CheckMail.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CheckMail - メール受信チェッカー" Width="500" Height="400"
        WindowStartupLocation="CenterScreen" Background="#F5F5F5"
        Closing="Window_Closing" StateChanged="Window_StateChanged">

    <!-- ウィンドウ内で使用するスタイル定義 -->
    <Window.Resources>
        <!-- 青い背景色の操作ボタン用スタイル -->
        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Background" Value="#4285F4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- ========== ヘッダー部: アプリ名・ステータス・操作ボタン ========== -->
        <Border DockPanel.Dock="Top" Background="White" BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="16,10">
            <DockPanel>
                <!-- 右側: 操作ボタン -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <!-- 即時メールチェック実行ボタン -->
                    <Button Content="今すぐチェック" Click="CheckNow_Click" Style="{StaticResource ActionButton}" Margin="0,0,8,0"/>
                    <!-- 設定画面表示ボタン -->
                    <Button Content="設定" Click="Settings_Click" Padding="16,6" FontSize="13" Cursor="Hand"/>
                </StackPanel>
                <!-- 左側: アプリ名とステータステキスト -->
                <StackPanel>
                    <TextBlock Text="CheckMail" FontSize="18" FontWeight="SemiBold" Foreground="#333"/>
                    <!-- ステータス表示(最終チェック時刻、未読合計、エラー等) -->
                    <TextBlock x:Name="StatusText" Text="起動中..." FontSize="11" Foreground="#888" Margin="0,2,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ========== 一覧部: 各アカウントの未読状況カード ========== -->
        <ListView x:Name="AccountListView" BorderThickness="0" Background="Transparent" Margin="8">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <!-- アカウント情報カード(白背景、角丸ボーダー) -->
                    <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,2" Width="440">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <!-- 左側: アカウント名・メールアドレス・エラー -->
                                <ColumnDefinition Width="*"/>
                                <!-- 右側: 未読数バッジ・最終チェック時刻 -->
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- 左側: アカウント情報 -->
                            <StackPanel Grid.Column="0">
                                <!-- アカウント表示名 -->
                                <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="SemiBold" Foreground="#333"/>
                                <!-- メールアドレス -->
                                <TextBlock Text="{Binding EmailAddress}" FontSize="11" Foreground="#888" Margin="0,2,0,0"/>
                                <!-- エラーメッセージ(エラー発生時のみ表示、NullToCollapsedコンバーター使用) -->
                                <TextBlock x:Name="ErrorText" Text="{Binding LastError}" FontSize="11" Foreground="#EA4335" Margin="0,2,0,0"
                                           Visibility="{Binding LastError, Converter={StaticResource NullToCollapsed}, FallbackValue=Collapsed}"/>
                            </StackPanel>

                            <!-- 右側: 未読数バッジと最終チェック時刻 -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <!-- 未読数バッジ(CountToColorコンバーターで色を動的変更) -->
                                <Border Background="{Binding UnreadCount, Converter={StaticResource CountToColor}}"
                                        CornerRadius="12" Padding="10,4" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding UnreadCount, StringFormat='{}{0}通'}"
                                               Foreground="White" FontSize="13" FontWeight="Bold"/>
                                </Border>
                                <!-- 最終チェック時刻 -->
                                <TextBlock Text="{Binding LastChecked, StringFormat='最終: {0:HH:mm:ss}', FallbackValue=''}"
                                           FontSize="10" Foreground="#AAA" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </DockPanel>
</Window>
