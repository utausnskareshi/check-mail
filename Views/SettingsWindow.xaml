<!-- ========================================================================
     SettingsWindow.xaml
     設定画面の画面定義
     ========================================================================
     メールアカウントの追加・編集・削除と、一般設定を管理する画面。
     モーダルダイアログとして表示される(リサイズ不可、画面中央に配置)。

     画面構成(4行のGridレイアウト):
       Row 0: ヘッダー(タイトル)
       Row 1: アカウント管理エリア(左: 一覧リスト、右: 詳細編集フォーム)
       Row 2: 一般設定エリア(チェック間隔、自動起動、通知)
       Row 3: 操作ボタン(キャンセル、全て保存して閉じる)

     スタイル定義:
       - TextBox: 統一的なパディング・マージン・フォントサイズ
       - PasswordBox: TextBoxと同様の見た目
       - Label: コンパクトなラベルスタイル
       - PrimaryButton: 青い背景の主要操作ボタン
       - SecondaryButton: デフォルトスタイルの補助操作ボタン
     ======================================================================== -->
<Window x:Class="CheckMail.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CheckMail - 設定" Width="650" Height="550"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F5F5F5">

    <!-- ========== 画面内で共通使用するスタイル定義 ========== -->
    <Window.Resources>
        <!-- テキスト入力フィールドの共通スタイル -->
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="0,2,0,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <!-- パスワード入力フィールドの共通スタイル -->
        <Style TargetType="PasswordBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="0,2,0,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <!-- ラベルの共通スタイル -->
        <Style TargetType="Label">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <!-- 主要操作ボタン(青背景・白文字) -->
        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Background" Value="#4285F4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <!-- 補助操作ボタン(デフォルトスタイル) -->
        <Style TargetType="Button" x:Key="SecondaryButton">
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <!-- ========== メインレイアウト(4行グリッド) ========== -->
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Row 0: ヘッダー -->
            <RowDefinition Height="*"/>     <!-- Row 1: アカウント管理(可変高さ) -->
            <RowDefinition Height="Auto"/>  <!-- Row 2: 一般設定 -->
            <RowDefinition Height="Auto"/>  <!-- Row 3: 操作ボタン -->
        </Grid.RowDefinitions>

        <!-- ========== Row 0: ヘッダー(画面タイトル) ========== -->
        <TextBlock Grid.Row="0" Text="メールアカウント設定" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <!-- ========== Row 1: アカウント管理エリア(左右2カラム) ========== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>  <!-- 左: アカウント一覧 -->
                <ColumnDefinition Width="*"/>    <!-- 右: 詳細編集フォーム -->
            </Grid.ColumnDefinitions>

            <!-- 左カラム: アカウント一覧リスト -->
            <Border Grid.Column="0" Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Margin="0,0,8,0">
                <DockPanel>
                    <!-- 下部: アカウント追加(＋)/削除(－)ボタン -->
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Center" Margin="4">
                        <Button Content="＋" Width="30" Click="AddAccount_Click" ToolTip="アカウント追加"/>
                        <Button Content="－" Width="30" Margin="4,0,0,0" Click="RemoveAccount_Click" ToolTip="アカウント削除"/>
                    </StackPanel>
                    <!-- アカウント一覧(表示名をリスト表示) -->
                    <ListBox x:Name="AccountList" SelectionChanged="AccountList_SelectionChanged"
                             BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" Padding="4,2"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- 右カラム: 選択中アカウントの詳細編集フォーム -->
            <Border Grid.Column="1" Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto" x:Name="DetailPanel">
                    <StackPanel>
                        <!-- 表示名: 画面やトレイ通知に表示されるアカウント名 -->
                        <Label Content="表示名"/>
                        <TextBox x:Name="TxtDisplayName"/>

                        <!-- メールアドレス: 参考表示用 -->
                        <Label Content="メールアドレス"/>
                        <TextBox x:Name="TxtEmail"/>

                        <!-- サーバーとポート番号(横並び) -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <Label Content="サーバー"/>
                                <TextBox x:Name="TxtServer"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <Label Content="ポート"/>
                                <TextBox x:Name="TxtPort"/>
                            </StackPanel>
                        </Grid>

                        <!-- プロトコルとSSL設定(横並び) -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <!-- プロトコル選択: IMAP または POP3 -->
                                <Label Content="プロトコル"/>
                                <ComboBox x:Name="CmbProtocol" Margin="0,2,0,6" FontSize="13" Padding="6,4"
                                          SelectionChanged="CmbProtocol_SelectionChanged">
                                    <ComboBoxItem Content="IMAP"/>
                                    <ComboBoxItem Content="POP3"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <!-- SSL/TLS使用の有無 -->
                                <Label Content="SSL/TLS"/>
                                <CheckBox x:Name="ChkSsl" Margin="0,6,0,6" Content="SSL/TLSを使用" FontSize="13"/>
                            </StackPanel>
                        </Grid>

                        <!-- 認証ユーザー名 -->
                        <Label Content="ユーザー名"/>
                        <TextBox x:Name="TxtUserName"/>

                        <!-- パスワード(PasswordBoxでマスク表示) -->
                        <Label Content="パスワード"/>
                        <PasswordBox x:Name="TxtPassword"/>

                        <!-- アカウント有効/無効チェックボックス -->
                        <CheckBox x:Name="ChkEnabled" Margin="0,8,0,0" Content="このアカウントを有効にする" FontSize="13"/>

                        <!-- アカウント操作ボタン -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                            <!-- 接続テスト: 実際にサーバーへ接続して確認する -->
                            <Button Content="接続テスト" Click="TestConnection_Click" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                            <!-- 保存: 入力内容をメモリ上のモデルに一時保存する -->
                            <Button Content="保存" Click="SaveAccount_Click" Style="{StaticResource PrimaryButton}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ========== Row 2: 一般設定エリア ========== -->
        <Border Grid.Row="2" Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Margin="0,12,0,0" Padding="12">
            <StackPanel>
                <TextBlock Text="一般設定" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>  <!-- ラベル「チェック間隔:」 -->
                        <ColumnDefinition Width="80"/>    <!-- 間隔入力(分) -->
                        <ColumnDefinition Width="Auto"/>  <!-- 単位「分」 -->
                        <ColumnDefinition Width="*"/>     <!-- 自動起動・通知チェックボックス -->
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="チェック間隔:" VerticalAlignment="Center" FontSize="13"/>
                    <!-- メールチェック間隔(分単位、最小1分) -->
                    <TextBox x:Name="TxtInterval" Grid.Column="1" Margin="8,0,0,0" TextAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="分" VerticalAlignment="Center" Margin="4,0,0,0" FontSize="13"/>
                    <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right">
                        <!-- Windows起動時に自動起動するか(レジストリに登録) -->
                        <CheckBox x:Name="ChkStartWithWindows" Content="Windows起動時に自動起動" VerticalAlignment="Center" FontSize="13" Margin="0,0,16,0"/>
                        <!-- 新着メール検出時にバルーン通知を表示するか -->
                        <CheckBox x:Name="ChkShowNotification" Content="通知を表示" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ========== Row 3: 画面下部の操作ボタン ========== -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <!-- キャンセル: 変更を破棄して閉じる -->
            <Button Content="キャンセル" Click="Cancel_Click" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
            <!-- 全て保存して閉じる: 全設定をJSONファイルに書き込んで閉じる -->
            <Button Content="全て保存して閉じる" Click="SaveAll_Click" Style="{StaticResource PrimaryButton}"/>
        </StackPanel>
    </Grid>
</Window>
